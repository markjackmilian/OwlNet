@* Project-scoped sidebar navigation using MudBlazor NavMenu.
   Designed for the light sidebar — uses Color.Inherit so text and icon
   colors are driven by the theme's DrawerText / DrawerIcon palette values.

   Supports both expanded and mini drawer modes — MudBlazor handles text
   hiding in mini mode automatically.

   This component assumes it is only rendered when ActiveProjectService.ActiveProject
   is not null — the parent MainLayout controls visibility. Routes are dynamically
   constructed from the active project's ID.

   Nav structure:
     Dashboard  → /projects/{projectId}
     Board      → /projects/{projectId}/board
     Agents     → /projects/{projectId}/agents *@
@using OwlNet.Web.Services
@inject ActiveProjectService ActiveProjectService

<MudNavMenu Rounded="true" Color="Color.Inherit">

    @* Dashboard — project overview / landing page.
       Uses NavLinkMatch.All (exact match) so it is NOT highlighted
       when the user is on /board or /settings sub-routes. *@
    <MudNavLink Href="@($"/projects/{ActiveProjectService.ActiveProject!.Id}")"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Dashboard">
        Dashboard
    </MudNavLink>

    @* Board — kanban / task board for the active project.
       Uses NavLinkMatch.All (exact match) for precise highlighting. *@
    <MudNavLink Href="@($"/projects/{ActiveProjectService.ActiveProject!.Id}/board")"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.ViewKanban">
        Board
    </MudNavLink>

    @* Agents — AI agent definitions for the active project.
       Uses NavLinkMatch.Prefix so the item stays highlighted on sub-routes
       like /agents/new and /agents/{agentName}. *@
    <MudNavLink Href="@($"/projects/{ActiveProjectService.ActiveProject!.Id}/agents")"
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.SmartToy">
        Agents
    </MudNavLink>

</MudNavMenu>

@code {
    // No code-behind needed — routes are constructed inline from ActiveProjectService.
    // Mini/expanded drawer behavior is handled by MudBlazor's built-in CSS.
}
