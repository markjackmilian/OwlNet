@implements IDisposable

@inject NavigationManager NavigationManager

@* Sidebar navigation using MudBlazor NavMenu with grouped sections.
   Designed for the deep violet drawer background — uses Color.Inherit so
   text and icon colors are driven by the theme's DrawerText / DrawerIcon
   palette values rather than the default body text color.

   Supports both expanded and mini drawer modes: when IsExpanded is false
   (mini / collapsed), section labels are hidden because they don't fit
   in the narrow 72 px mini-drawer width. *@
<MudNavMenu Rounded="true" Color="Color.Inherit">

    @* ── Section: General ──────────────────────────────────────────────── *@
    @* Section label — only rendered when the drawer is expanded.
       In mini mode the 72 px width can't accommodate text labels,
       so we hide them to keep the sidebar clean. *@
    @if (IsExpanded)
    {
        <MudText Typo="Typo.overline" Class="nav-section-label mt-2 px-4">
            General
        </MudText>
    }

    <MudNavLink Href="/" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Dashboard">
        Dashboard
    </MudNavLink>

    @* ── Section: Account ──────────────────────────────────────────────── *@
    @if (IsExpanded)
    {
        <MudText Typo="Typo.overline" Class="nav-section-label mt-4 px-4">
            Account
        </MudText>
    }

    @* Identity account links — show profile/logout when authenticated, register/login otherwise *@
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="Account/Manage"
                        Icon="@Icons.Material.Filled.Person">
                @context.User.Identity?.Name
            </MudNavLink>
            <MudNavLink Href="@_logoutUrl"
                        Icon="@Icons.Material.Filled.Logout">
                Logout
            </MudNavLink>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="Account/Register"
                        Icon="@Icons.Material.Filled.PersonAdd">
                Register
            </MudNavLink>
            <MudNavLink Href="Account/Login"
                        Icon="@Icons.Material.Filled.Login">
                Login
            </MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    /// <summary>
    /// Indicates whether the parent drawer is in expanded (full-width) mode.
    /// When <c>false</c> the drawer is in mini/collapsed mode and section
    /// labels are hidden because they don't fit the narrow width.
    /// Defaults to <c>true</c> so the component works correctly even when
    /// the parameter is not explicitly passed from the parent layout.
    /// </summary>
    [Parameter]
    public bool IsExpanded { get; set; } = true;

    /// <summary>
    /// Tracks the current URL for the logout return-URL parameter.
    /// Updated on every navigation event so the logout link always
    /// redirects back to the page the user was on.
    /// </summary>
    private string? _currentUrl;

    /// <summary>
    /// Computed logout URL that includes the current page as the return destination.
    /// Note: The actual logout is handled by the Identity POST endpoint; this link
    /// navigates to a page that performs the POST.
    /// </summary>
    private string _logoutUrl => $"Account/Logout?returnUrl={Uri.EscapeDataString(_currentUrl ?? "")}";

    protected override void OnInitialized()
    {
        _currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
