@implements IDisposable

@inject NavigationManager NavigationManager

@* Sidebar navigation using MudBlazor NavMenu with grouped sections.
   Inspired by the "Mud Mini" dashboard design — section labels provide
   visual grouping while MudNavLinks handle routing and active-state highlighting. *@
<MudNavMenu Rounded="true" Color="Color.Primary">

    @* ── Section: General ──────────────────────────────────────────────── *@
    @* Section label styled as uppercase overline text with muted color,
       matching the "Mud Mini" dashboard sidebar aesthetic. *@
    <MudText Typo="Typo.overline" Class="nav-section-label mt-2 px-4">
        General
    </MudText>

    <MudNavLink Href="/" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Dashboard">
        Dashboard
    </MudNavLink>

    @* ── Section: Account ──────────────────────────────────────────────── *@
    <MudText Typo="Typo.overline" Class="nav-section-label mt-4 px-4">
        Account
    </MudText>

    @* Identity account links — show profile/logout when authenticated, register/login otherwise *@
    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="Account/Manage"
                        Icon="@Icons.Material.Filled.Person">
                @context.User.Identity?.Name
            </MudNavLink>
            <MudNavLink Href="@_logoutUrl"
                        Icon="@Icons.Material.Filled.Logout">
                Logout
            </MudNavLink>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="Account/Register"
                        Icon="@Icons.Material.Filled.PersonAdd">
                Register
            </MudNavLink>
            <MudNavLink Href="Account/Login"
                        Icon="@Icons.Material.Filled.Login">
                Login
            </MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    /// <summary>
    /// Tracks the current URL for the logout return-URL parameter.
    /// </summary>
    private string? _currentUrl;

    /// <summary>
    /// Computed logout URL that includes the current page as the return destination.
    /// Note: The actual logout is handled by the Identity POST endpoint; this link
    /// navigates to a page that performs the POST.
    /// </summary>
    private string _logoutUrl => $"Account/Logout?returnUrl={Uri.EscapeDataString(_currentUrl ?? "")}";

    protected override void OnInitialized()
    {
        _currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
