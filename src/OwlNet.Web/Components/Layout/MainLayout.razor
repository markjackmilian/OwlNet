@inherits LayoutComponentBase
@implements IDisposable

@inject NavigationManager NavigationManager

@* MudBlazor theme provider — uses the custom OwlNet violet/indigo theme.
   Dark mode is two-way bound so the toggle in the AppBar updates the provider. *@
<MudThemeProvider Theme="@OwlNetTheme.Theme" @bind-IsDarkMode="_isDarkMode" />

@* MudBlazor service providers for popovers, dialogs, and snackbar notifications *@
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @* ── Top application bar ─────────────────────────────────────────────
       Flat (Elevation 0) with dense layout for a minimal header.
       Left side: hamburger toggle for drawer expand/collapse + search button.
       Right side: dark mode toggle, notification bell, and user avatar. *@
    <MudAppBar Elevation="0" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer"
                       aria-label="Toggle navigation drawer" />
        <MudIconButton Icon="@Icons.Material.Filled.Search"
                       Color="Color.Inherit"
                       aria-label="Search (coming soon)" />
        <MudSpacer />
        @* Dark/light mode toggle — icon changes based on current mode *@
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ToggleDarkMode"
                       aria-label="Toggle dark mode" />
        @* Notification bell — decorative placeholder for future notification system *@
        <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                       Color="Color.Inherit"
                       aria-label="Notifications" />
        @* User avatar placeholder — will be replaced with real user data when auth is wired up *@
        <MudAvatar Size="Size.Small" Class="ml-2" aria-label="User menu">
            <MudIcon Icon="@Icons.Material.Filled.Person" />
        </MudAvatar>
    </MudAppBar>

    @* ── Collapsible mini drawer (deep violet sidebar) ───────────────────
       Uses DrawerVariant.Mini so the drawer toggles between:
         - Expanded (260px): shows icons + text labels + badges + footer
         - Mini/collapsed (72px): shows icons only, centered
       The deep violet background color comes from the theme palette
       (DrawerBackground) — no hardcoded colors here.
       ClipMode.Always keeps the drawer below the AppBar.
       Elevation 0 with a right border (applied in app.css) for a flat look. *@
    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="0"
               Variant="@DrawerVariant.Mini"
               MiniWidth="72px"
               Width="260px"
               OpenMiniOnHover="false">

        @* Flex container to push the footer to the bottom of the drawer.
           The nav menu section uses flex:1 to fill available space,
           while the footer stays pinned at the bottom. *@
        <div class="drawer-content">

            @* ── Brand header ────────────────────────────────────────────
               Expanded: owl icon + "OwlNet" text side by side.
               Mini: owl icon only, centered in the narrower drawer. *@
            <div class="brand-header @(_drawerOpen ? "brand-header--expanded" : "brand-header--mini")">
                <MudIcon Icon="@Icons.Material.Filled.NightsStay"
                         Size="Size.Large"
                         Class="brand-icon" />
                @if (_drawerOpen)
                {
                    <MudText Typo="Typo.h6" Class="brand-text ml-2">OwlNet</MudText>
                }
            </div>

            @* ── Search bar ──────────────────────────────────────────────
               Decorative search input shown only when the drawer is expanded.
               Uses a semi-transparent background to blend with the dark violet
               sidebar. No actual search functionality yet — placeholder only. *@
            @if (_drawerOpen)
            {
                <div class="drawer-search">
                    <MudTextField T="string"
                                  Placeholder="Search"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Margin="Margin.Dense"
                                  Class="drawer-search-field" />
                </div>
            }

            @* ── Navigation menu ─────────────────────────────────────────
               Scrollable area that fills the remaining vertical space between
               the search bar and the footer. Receives the drawer state so it
               can hide section labels and badges in mini (collapsed) mode. *@
            <div class="drawer-nav-scroll">
                <NavMenu IsExpanded="_drawerOpen" />
            </div>

            @* ── Drawer footer ───────────────────────────────────────────
               Pinned to the bottom of the drawer via flexbox.
               Contains: "Go Pro" upsell link + user profile with logout.
               In mini mode, only the user avatar is shown (centered). *@
            <div class="drawer-footer">
                @if (_drawerOpen)
                {
                    @* "Go Pro" upsell section — decorative, no functionality yet.
                       Styled as a subtle call-to-action with a star icon. *@
                    <MudDivider Class="my-1" DividerType="DividerType.FullWidth" />
                    <div class="drawer-go-pro">
                        <MudIcon Icon="@Icons.Material.Filled.Star"
                                 Size="Size.Small"
                                 Class="go-pro-icon" />
                        <MudText Typo="Typo.body2" Class="go-pro-text">Go Pro</MudText>
                    </div>
                    <MudDivider Class="my-1" DividerType="DividerType.FullWidth" />
                }

                @* User profile — shows avatar + name + role when expanded,
                   or just a centered avatar in mini mode.
                   Logout button navigates to the Identity logout endpoint
                   with the current page as the return URL. *@
                <AuthorizeView>
                    <Authorized>
                        <div class="drawer-user-profile @(_drawerOpen ? "" : "drawer-user-profile--mini")">
                            <MudAvatar Size="Size.Medium" Color="Color.Primary" Class="drawer-user-avatar">
                                @(context.User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")
                            </MudAvatar>
                            @if (_drawerOpen)
                            {
                                <div class="drawer-user-info">
                                    <MudText Typo="Typo.body2" Class="drawer-user-name">
                                        @context.User.Identity?.Name
                                    </MudText>
                                    <MudText Typo="Typo.caption" Class="drawer-user-role">
                                        Basic Member
                                    </MudText>
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                                               Size="Size.Small"
                                               Href="@_logoutUrl"
                                               Class="drawer-logout-btn"
                                               aria-label="Logout" />
                            }
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </MudDrawer>

    @* ── Main content area ───────────────────────────────────────────────
       Full width with comfortable padding for a modern dashboard feel.
       ErrorBoundary wraps the routed page content for graceful failure handling. *@
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent>
                    @* User-friendly error fallback — never shows raw exception details *@
                    <MudCard Class="error-card">
                        <MudCardContent>
                            <MudText Typo="Typo.h5">
                                Something went wrong
                            </MudText>
                            <MudText>
                                An unexpected error occurred. Please try again.
                            </MudText>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="@RecoverFromError"
                                       Class="error-retry-button">
                                Retry
                            </MudButton>
                        </MudCardContent>
                    </MudCard>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private ErrorBoundary? _errorBoundary;

    /// <summary>
    /// Controls whether the navigation drawer is expanded (true) or in mini/collapsed mode (false).
    /// When expanded, the drawer shows icons + text labels at 260px width.
    /// When collapsed, the drawer shows icons only at 72px width (mini mode).
    /// Defaults to expanded so the user sees full navigation on first load.
    /// </summary>
    private bool _drawerOpen = true;

    /// <summary>
    /// Controls whether dark mode is active.
    /// Bound to <see cref="MudThemeProvider"/> via @bind-IsDarkMode.
    /// </summary>
    private bool _isDarkMode;

    /// <summary>
    /// Tracks the current URL for the logout return-URL parameter.
    /// Updated on every navigation event so the logout link always
    /// redirects back to the page the user was on.
    /// </summary>
    private string? _currentUrl;

    /// <summary>
    /// Computed logout URL that includes the current page as the return destination.
    /// The actual logout is handled by the Identity POST endpoint; this link
    /// navigates to a page that performs the POST.
    /// </summary>
    private string _logoutUrl => $"Account/Logout?returnUrl={Uri.EscapeDataString(_currentUrl ?? "")}";

    protected override void OnInitialized()
    {
        // Track the current URL for the logout return-URL parameter
        _currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    /// <summary>
    /// Toggles the navigation drawer between expanded and mini (collapsed) states.
    /// </summary>
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    /// <summary>
    /// Toggles between dark and light theme modes.
    /// </summary>
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;

    /// <summary>
    /// Recovers from a rendering error by resetting the error boundary state.
    /// </summary>
    private void RecoverFromError() => _errorBoundary?.Recover();

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
