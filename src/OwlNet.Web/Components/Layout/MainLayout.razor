@inherits LayoutComponentBase

@* MudBlazor theme provider — uses the custom OwlNet violet/indigo theme.
   Dark mode is two-way bound so the toggle in the AppBar updates the provider. *@
<MudThemeProvider Theme="@OwlNetTheme.Theme" @bind-IsDarkMode="_isDarkMode" />

@* MudBlazor service providers for popovers, dialogs, and snackbar notifications *@
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @* Top application bar — flat (Elevation 0) with dense layout for a minimal header.
       Left side: drawer toggle + decorative search button.
       Right side: dark mode toggle, notification bell, and user avatar placeholder. *@
    <MudAppBar Elevation="0" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer"
                       aria-label="Toggle navigation drawer" />
        <MudIconButton Icon="@Icons.Material.Filled.Search"
                       Color="Color.Inherit"
                       aria-label="Search (coming soon)" />
        <MudSpacer />
        @* Dark/light mode toggle — icon changes based on current mode *@
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ToggleDarkMode"
                       aria-label="Toggle dark mode" />
        @* Notification bell — decorative placeholder for future notification system *@
        <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                       Color="Color.Inherit"
                       aria-label="Notifications" />
        @* User avatar placeholder — will be replaced with real user data when auth is wired up *@
        <MudAvatar Size="Size.Small" Class="ml-2" aria-label="User menu">
            <MudIcon Icon="@Icons.Material.Filled.Person" />
        </MudAvatar>
    </MudAppBar>

    @* Collapsible left-side drawer — flat (Elevation 0) with a right border for separation.
       The border is applied via global CSS (app.css) targeting .mud-drawer because Blazor
       CSS isolation scoping attributes are not present on MudBlazor-rendered elements. *@
    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="0">
        @* Brand header — owl icon + app name styled as a compact brand mark *@
        <MudDrawerHeader Class="brand-header">
            <MudIcon Icon="@Icons.Material.Filled.NightsStay"
                     Color="Color.Primary"
                     Size="Size.Large" />
            <MudText Typo="Typo.h6" Color="Color.Primary" Class="ml-2">OwlNet</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    @* Main content area — full width with comfortable padding for modern dashboard feel.
       ErrorBoundary wraps the routed page content for graceful failure handling. *@
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent>
                    <MudCard Class="error-card">
                        <MudCardContent>
                            <MudText Typo="Typo.h5">
                                Something went wrong
                            </MudText>
                            <MudText>
                                An unexpected error occurred. Please try again.
                            </MudText>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="@RecoverFromError"
                                       Class="error-retry-button">
                                Retry
                            </MudButton>
                        </MudCardContent>
                    </MudCard>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private ErrorBoundary? _errorBoundary;

    /// <summary>
    /// Controls whether the navigation drawer is open or collapsed.
    /// Defaults to open so the user sees navigation on first load.
    /// </summary>
    private bool _drawerOpen = true;

    /// <summary>
    /// Controls whether dark mode is active.
    /// Bound to <see cref="MudThemeProvider"/> via @bind-IsDarkMode.
    /// </summary>
    private bool _isDarkMode;

    /// <summary>
    /// Toggles the navigation drawer between open and collapsed states.
    /// </summary>
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    /// <summary>
    /// Toggles between dark and light theme modes.
    /// </summary>
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;

    /// <summary>
    /// Recovers from a rendering error by resetting the error boundary state.
    /// </summary>
    private void RecoverFromError() => _errorBoundary?.Recover();
}
