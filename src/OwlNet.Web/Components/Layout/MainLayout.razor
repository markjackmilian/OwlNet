@inherits LayoutComponentBase
@implements IDisposable

@using OwlNet.Application.Common.Models
@using OwlNet.Web.Services

@inject NavigationManager NavigationManager
@inject ActiveProjectService ActiveProjectService
@inject IDialogService DialogService

@* MudBlazor theme provider — uses the minimalist warm OwlNet theme.
   Dark mode is two-way bound so the toggle in the topbar updates the provider. *@
<MudThemeProvider Theme="@OwlNetTheme.Theme" @bind-IsDarkMode="_isDarkMode" />

@* MudBlazor service providers for popovers, dialogs, and snackbar notifications *@
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @* ── Top application bar ─────────────────────────────────────────────
       Flat, minimal header.
       Left:  hamburger (project-only) → brand → project selector.
       Right: settings gear → OpenCode status → dark mode → notifications → user avatar. *@
    <MudAppBar Elevation="0" Dense="true" Class="main-appbar">

        @* ── Left side ───────────────────────────────────────────────────── *@

        @* Hamburger toggle — only rendered when a project is active,
           because the sidebar is hidden otherwise (FR-14, FR-15). *@
        @if (ActiveProjectService.ActiveProject is not null)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           OnClick="@ToggleDrawer"
                           aria-label="Toggle navigation drawer" />
        }

        @* ── OwlNet brand ────────────────────────────────────────────────
           Owl icon + "OwlNet" text displayed inline in the topbar.
           Always visible regardless of project context (FR-11). *@
        <div class="topbar-brand">
            <MudIcon Icon="@Icons.Material.Rounded.NightsStay"
                     Size="Size.Medium"
                     Class="brand-icon" />
            <MudText Typo="Typo.h6" Class="brand-text ml-2">OwlNet</MudText>
        </div>

        @* ── Active project indicator ────────────────────────────────────
           Shows the currently active project name, or a placeholder prompt.
           Clicking opens the project selector modal (FR-16). *@
        <MudButton Variant="Variant.Text"
                   Color="Color.Inherit"
                   StartIcon="@Icons.Material.Filled.Folder"
                   OnClick="@OpenProjectSelectorAsync"
                   Class="ml-2 project-indicator"
                   aria-label="Select project">
            @if (ActiveProjectService.ActiveProject is not null)
            {
                @ActiveProjectService.ActiveProject.Name
            }
            else
            {
                <MudText Typo="Typo.body2" Style="opacity: 0.7;">Select a project</MudText>
            }
        </MudButton>

        <MudSpacer />

        @* ── Right side ──────────────────────────────────────────────────── *@

        @* Settings gear — navigates to global application settings (FR-12, FR-13).
           Positioned first in the right-side group, before the OpenCode indicator. *@
        <MudIconButton Icon="@Icons.Material.Filled.Settings"
                       Color="Color.Inherit"
                       OnClick="@NavigateToSettings"
                       aria-label="Application settings" />

        @* ── OpenCode Server status indicator ────────────────────────────
           Compact badge showing server connection state (green/red dot + version).
           Clicking navigates to the Settings page for server management. *@
        <OpenCodeStatusIndicator />

        @* Dark/light mode toggle *@
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Rounded.LightMode : Icons.Material.Rounded.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ToggleDarkMode"
                       aria-label="Toggle dark mode" />

        @* Notification bell *@
        <MudIconButton Icon="@Icons.Material.Rounded.NotificationsNone"
                       Color="Color.Inherit"
                       aria-label="Notifications" />

        @* User avatar *@
        <MudAvatar Size="Size.Small" Class="ml-2" Variant="Variant.Outlined" aria-label="User menu">
            <MudIcon Icon="@Icons.Material.Rounded.Person" />
        </MudAvatar>
    </MudAppBar>

    @* ── Collapsible mini drawer (project-scoped sidebar) ─────────────────
       Only rendered when a project is active (FR-1, FR-2).
       Contains project-scoped navigation items only — brand and footer
       have been relocated to the topbar / removed. *@
    @if (ActiveProjectService.ActiveProject is not null)
    {
        <MudDrawer @bind-Open="_drawerOpen"
                   ClipMode="DrawerClipMode.Always"
                   Elevation="0"
                   Variant="@DrawerVariant.Mini"
                   MiniWidth="68px"
                   Width="250px"
                   OpenMiniOnHover="false"
                   Class="main-drawer">

            <div class="drawer-content">
                @* ── Navigation menu ─────────────────────────────────────────
                   Project-scoped navigation items (Dashboard, Board, Settings).
                   Fills the full vertical space now that brand header and
                   drawer footer have been removed (FR-9, FR-10). *@
                <div class="drawer-nav-scroll">
                    <NavMenu />
                </div>
            </div>
        </MudDrawer>
    }

    @* ── Main content area ───────────────────────────────────────────────
       Comfortable padding for a spacious, airy dashboard feel. *@
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent>
                    <MudCard Class="error-card">
                        <MudCardContent>
                            <MudText Typo="Typo.h5">
                                Something went wrong
                            </MudText>
                            <MudText Class="mt-2">
                                An unexpected error occurred. Please try again.
                            </MudText>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="@RecoverFromError"
                                       Class="mt-4">
                                Retry
                            </MudButton>
                        </MudCardContent>
                    </MudCard>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private ErrorBoundary? _errorBoundary;

    /// <summary>Controls whether the navigation drawer is expanded or in mini/collapsed mode.</summary>
    private bool _drawerOpen = true;

    /// <summary>Controls whether dark mode is active.</summary>
    private bool _isDarkMode;

    /// <summary>Whether the active project has been restored from sessionStorage.</summary>
    private bool _projectRestored;

    protected override void OnInitialized()
    {
        ActiveProjectService.OnActiveProjectChanged += OnActiveProjectChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_projectRestored)
        {
            _projectRestored = true;
            await ActiveProjectService.RestoreFromSessionStorageAsync();
            StateHasChanged();
        }
    }

    /// <summary>Called when the active project changes — triggers a re-render of the topbar indicator.</summary>
    private void OnActiveProjectChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Opens the project selector modal dialog.
    /// When the user selects a project, navigates to that project's dashboard.
    /// </summary>
    private async Task OpenProjectSelectorAsync()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true,
            NoHeader = false
        };

        var dialog = await DialogService.ShowAsync<OwlNet.Web.Components.Projects.ProjectSelectorModal>(
            string.Empty,
            options);

        var result = await dialog.Result;

        // Navigate to the project dashboard only when the user actively selected a project
        // (not when they closed/cancelled the dialog)
        if (result is { Canceled: false, Data: ProjectDto project })
        {
            NavigationManager.NavigateTo($"/projects/{project.Id}");
        }
    }

    /// <summary>Navigates to the global application settings page (FR-12).</summary>
    private void NavigateToSettings() => NavigationManager.NavigateTo("/settings");

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
    private void RecoverFromError() => _errorBoundary?.Recover();

    public void Dispose()
    {
        ActiveProjectService.OnActiveProjectChanged -= OnActiveProjectChanged;
    }
}
