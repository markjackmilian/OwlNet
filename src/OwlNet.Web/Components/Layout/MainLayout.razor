@inherits LayoutComponentBase
@implements IDisposable

@inject NavigationManager NavigationManager

@* MudBlazor theme provider — uses the minimalist warm OwlNet theme.
   Dark mode is two-way bound so the toggle in the drawer footer updates the provider. *@
<MudThemeProvider Theme="@OwlNetTheme.Theme" @bind-IsDarkMode="_isDarkMode" />

@* MudBlazor service providers for popovers, dialogs, and snackbar notifications *@
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @* ── Top application bar ─────────────────────────────────────────────
       Flat, minimal header. Left: hamburger toggle. Right: dark mode, notifications, user. *@
    <MudAppBar Elevation="0" Dense="true" Class="main-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer"
                       aria-label="Toggle navigation drawer" />
        <MudSpacer />
        @* Dark/light mode toggle *@
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Rounded.LightMode : Icons.Material.Rounded.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ToggleDarkMode"
                       aria-label="Toggle dark mode" />
        @* Notification bell *@
        <MudIconButton Icon="@Icons.Material.Rounded.NotificationsNone"
                       Color="Color.Inherit"
                       aria-label="Notifications" />
        @* User avatar *@
        <MudAvatar Size="Size.Small" Class="ml-2" Variant="Variant.Outlined" aria-label="User menu">
            <MudIcon Icon="@Icons.Material.Rounded.Person" />
        </MudAvatar>
    </MudAppBar>

    @* ── Collapsible mini drawer (light sidebar) ──────────────────────────
       Light background driven by theme DrawerBackground palette.
       Mini mode at 68px, expanded at 250px for a tighter, cleaner feel. *@
    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="0"
               Variant="@DrawerVariant.Mini"
               MiniWidth="68px"
               Width="250px"
               OpenMiniOnHover="false"
               Class="main-drawer">

        <div class="drawer-content">

            @* ── Brand header ────────────────────────────────────────────
               Expanded: owl icon + "OwlNet" text. Mini: icon only, centered. *@
            <div class="brand-header @(_drawerOpen ? "brand-header--expanded" : "brand-header--mini")">
                <MudIcon Icon="@Icons.Material.Rounded.NightsStay"
                         Size="Size.Medium"
                         Class="brand-icon" />
                @if (_drawerOpen)
                {
                    <MudText Typo="Typo.h6" Class="brand-text ml-2">OwlNet</MudText>
                }
            </div>

            @* ── Navigation menu ─────────────────────────────────────────
               Fills remaining vertical space. *@
            <div class="drawer-nav-scroll">
                <NavMenu IsExpanded="_drawerOpen" />
            </div>

            @* ── Drawer footer ───────────────────────────────────────────
               User profile + dark/light toggle at the bottom. *@
            <div class="drawer-footer">
                @* Dark / Light toggle row — mirrors the reference image *@
                @if (_drawerOpen)
                {
                    <div class="drawer-theme-toggle">
                        <MudIconButton Icon="@Icons.Material.Rounded.DarkMode"
                                       Size="Size.Small"
                                       Class="@(_isDarkMode ? "theme-toggle-active" : "theme-toggle-inactive")"
                                       OnClick="@(() => _isDarkMode = true)"
                                       aria-label="Dark mode" />
                        <MudText Typo="Typo.caption" Class="theme-toggle-label">Dark</MudText>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Rounded.LightMode"
                                       Size="Size.Small"
                                       Class="@(!_isDarkMode ? "theme-toggle-active" : "theme-toggle-inactive")"
                                       OnClick="@(() => _isDarkMode = false)"
                                       aria-label="Light mode" />
                        <MudText Typo="Typo.caption" Class="theme-toggle-label">Light</MudText>
                    </div>
                }

                @* User profile *@
                <AuthorizeView>
                    <Authorized>
                        <div class="drawer-user-profile @(_drawerOpen ? "" : "drawer-user-profile--mini")">
                            <MudAvatar Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" Class="drawer-user-avatar">
                                @(context.User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")
                            </MudAvatar>
                            @if (_drawerOpen)
                            {
                                <div class="drawer-user-info">
                                    <MudText Typo="Typo.body2" Class="drawer-user-name">
                                        @context.User.Identity?.Name
                                    </MudText>
                                    <MudText Typo="Typo.caption" Class="drawer-user-role">
                                        Member
                                    </MudText>
                                </div>
                                @* POST form for logout — the /Account/Logout endpoint requires
                                   POST + form-encoded returnUrl. Antiforgery is disabled on
                                   this endpoint because tokens generated during SSR prerender
                                   are unreliable when submitted from interactive circuits. *@
                                <form method="post" action="Account/Logout" style="margin: 0;">
                                    <input type="hidden" name="returnUrl" value="@_currentUrl" />
                                    <MudIconButton Icon="@Icons.Material.Rounded.Logout"
                                                   Size="Size.Small"
                                                   ButtonType="ButtonType.Submit"
                                                   Class="drawer-logout-btn"
                                                   aria-label="Logout" />
                                </form>
                            }
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </MudDrawer>

    @* ── Main content area ───────────────────────────────────────────────
       Comfortable padding for a spacious, airy dashboard feel. *@
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent>
                    <MudCard Class="error-card">
                        <MudCardContent>
                            <MudText Typo="Typo.h5">
                                Something went wrong
                            </MudText>
                            <MudText Class="mt-2">
                                An unexpected error occurred. Please try again.
                            </MudText>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="@RecoverFromError"
                                       Class="mt-4">
                                Retry
                            </MudButton>
                        </MudCardContent>
                    </MudCard>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private ErrorBoundary? _errorBoundary;

    /// <summary>Controls whether the navigation drawer is expanded or in mini/collapsed mode.</summary>
    private bool _drawerOpen = true;

    /// <summary>Controls whether dark mode is active.</summary>
    private bool _isDarkMode;

    /// <summary>Tracks the current URL for the logout return-URL parameter.</summary>
    private string? _currentUrl;

    protected override void OnInitialized()
    {
        _currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
    private void RecoverFromError() => _errorBoundary?.Recover();

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
