@* Displays two-factor recovery codes after generation or reset.
   Uses our own StatusMessage component for operation feedback. *@

<StatusMessage Message="@StatusMessage" />

<MudText Typo="Typo.h5" Class="mb-2">Recovery codes</MudText>

@* Warning alert: emphasizes that codes must be stored securely *@
<MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="my-2">
    <MudText>
        <strong>Put these codes in a safe place.</strong>
    </MudText>
    <MudText>
        If you lose your device and don't have the recovery codes you will lose access to your account.
    </MudText>
</MudAlert>

@* List each recovery code in a monospace font for easy copying *@
<MudStack Spacing="1" Class="mt-3">
    @foreach (var recoveryCode in RecoveryCodes)
    {
        <MudText Typo="Typo.body2" Style="font-family: monospace;">@recoveryCode</MudText>
    }
</MudStack>

@code {
    [Parameter]
    public string[] RecoveryCodes { get; set; } = [];

    [Parameter]
    public string? StatusMessage { get; set; }
}
