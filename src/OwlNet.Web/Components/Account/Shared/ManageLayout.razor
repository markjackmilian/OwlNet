@inherits LayoutComponentBase
@layout OwlNet.Web.Components.Layout.MainLayout

@* Page heading for the account management section *@
<MudText Typo="Typo.h4" Class="mb-2">Manage your account</MudText>

<MudText Typo="Typo.h5" Class="mb-2">Change your account settings</MudText>
<MudDivider Class="mb-4" />

@* Responsive two-column layout: navigation sidebar + page content *@
<MudGrid>
    @* Left column: account management navigation menu *@
    <MudItem xs="12" md="3">
        <ManageNavMenu />
    </MudItem>

    @* Right column: routed page body content *@
    <MudItem xs="12" md="9">
        @Body
    </MudItem>
</MudGrid>
