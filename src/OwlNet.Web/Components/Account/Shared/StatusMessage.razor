@* StatusMessage: Displays a success or error alert based on a direct parameter
   or a one-time cookie set by IdentityRedirectManager after a redirect. *@

@if (!string.IsNullOrEmpty(DisplayMessage))
{
    @* Determine severity from message prefix: "Error..." maps to Error, everything else to Success *@
    <MudAlert Severity="@(DisplayMessage.StartsWith("Error") ? Severity.Error : Severity.Success)"
              Variant="Variant.Filled"
              Class="my-2">
        @DisplayMessage
    </MudAlert>
}

@code {
    private string? messageFromCookie;

    [Parameter]
    public string? Message { get; set; }

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private string? DisplayMessage => Message ?? messageFromCookie;

    protected override void OnInitialized()
    {
        messageFromCookie = HttpContext.Request.Cookies[IdentityRedirectManager.StatusCookieName];

        if (messageFromCookie is not null)
        {
            HttpContext.Response.Cookies.Delete(IdentityRedirectManager.StatusCookieName);
        }
    }
}
