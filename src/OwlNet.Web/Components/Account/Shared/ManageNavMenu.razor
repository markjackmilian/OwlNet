@using Microsoft.AspNetCore.Identity
@using OwlNet.Infrastructure.Identity

@inject SignInManager<ApplicationUser> SignInManager

@* Sidebar navigation for account management pages.
   Each link uses a Material icon for quick visual identification. *@
<MudNavMenu>
    <MudNavLink Href="Account/Manage"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Person">
        Profile
    </MudNavLink>

    <MudNavLink Href="Account/Manage/Email"
                Icon="@Icons.Material.Filled.Email">
        Email
    </MudNavLink>

    <MudNavLink Href="Account/Manage/ChangePassword"
                Icon="@Icons.Material.Filled.Lock">
        Password
    </MudNavLink>

    @* External logins link is only shown when at least one external auth provider is configured *@
    @if (hasExternalLogins)
    {
        <MudNavLink Href="Account/Manage/ExternalLogins"
                    Icon="@Icons.Material.Filled.Link">
            External logins
        </MudNavLink>
    }

    <MudNavLink Href="Account/Manage/TwoFactorAuthentication"
                Icon="@Icons.Material.Filled.Security">
        Two-factor authentication
    </MudNavLink>

    <MudNavLink Href="Account/Manage/PersonalData"
                Icon="@Icons.Material.Filled.Storage">
        Personal data
    </MudNavLink>
</MudNavMenu>

@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }
}
