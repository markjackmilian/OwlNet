<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    @* MudBlazor — Google Poppins font (required by Material Design) *@
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    @* MudBlazor — Material Design component styles *@
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="OwlNet.Web.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="@PageRenderMode" />
</head>

<body>
    @* Render mode is determined dynamically: pages marked with
       [ExcludeFromInteractiveRouting] (Identity Account pages) render in
       static SSR (null), while all other pages use InteractiveServer. *@
    <Routes @rendermode="@PageRenderMode" />

    @* Blazor error UI — shown when an unhandled exception occurs in a circuit *@
    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">🗙</span>
    </div>

    @* MudBlazor — JavaScript interop for interactive components *@
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    @* Blazor Server SignalR connection script *@
    <script src="_framework/blazor.web.js"></script>
</body>

</html>

@code {
    /// <summary>
    /// HttpContext is available during static SSR prerendering.
    /// Used to check whether the current page accepts interactive routing.
    /// </summary>
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    /// <summary>
    /// Determines the render mode for the current page.
    /// Pages with [ExcludeFromInteractiveRouting] (e.g., Identity Account pages)
    /// return null (static SSR); all other pages use InteractiveServer.
    /// </summary>
    private IComponentRenderMode? PageRenderMode
        => HttpContext.AcceptsInteractiveRouting() ? InteractiveServer : null;
}
