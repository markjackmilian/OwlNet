    // ═══════════════════════════════════════════════════════════════════════════
    //  Drag & Drop Handler
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>
    /// Called when a task card is dropped into a new (or the same) drop zone.
    /// Parses the zone identifier back to a KanbanStatus enum and updates the
    /// task's Status property, which causes MudDropContainer to re-evaluate
    /// which zone the card belongs to.
    /// </summary>
    private void OnItemDropped(MudItemDropInfo<KanbanTask> info)
    {
        if (info.Item is not null &&
            Enum.TryParse<KanbanStatus>(info.DropzoneIdentifier, out var newStatus))
        {
            info.Item.Status = newStatus;
        }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  Helper Methods — formatting, color mapping, and column counts
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>
    /// Returns the number of tasks currently in a given column.
    /// Used by column headers to display the live count badge.
    /// </summary>
    private int GetColumnCount(KanbanStatus status) =>
        _tasks.Count(t => t.Status == status);

    /// <summary>
    /// Maps a TaskPriority enum value to a CSS class name for the priority badge.
    /// Each class applies a distinct background color matching the reference design.
    /// </summary>
    private static string GetPriorityClass(TaskPriority priority) => priority switch
    {
        TaskPriority.Important          => "kanban-card-priority--important",
        TaskPriority.HighPriority       => "kanban-card-priority--high",
        TaskPriority.Meh                => "kanban-card-priority--meh",
        TaskPriority.OK                 => "kanban-card-priority--ok",
        TaskPriority.LowPriority        => "kanban-card-priority--low",
        TaskPriority.IDontKnow          => "kanban-card-priority--idk",
        TaskPriority.MaybeImportant     => "kanban-card-priority--maybe",
        TaskPriority.NotThatImportant   => "kanban-card-priority--not",
        _                               => ""
    };

    /// <summary>
    /// Returns the human-readable label for a priority badge.
    /// </summary>
    private static string GetPriorityLabel(TaskPriority priority) => priority switch
    {
        TaskPriority.Important          => "Important",
        TaskPriority.HighPriority       => "High Priority",
        TaskPriority.Meh                => "Meh",
        TaskPriority.OK                 => "OK",
        TaskPriority.LowPriority        => "Low Priority",
        TaskPriority.IDontKnow          => "I don't know",
        TaskPriority.MaybeImportant     => "Maybe important",
        TaskPriority.NotThatImportant   => "Not that Important",
        _                               => ""
    };

    /// <summary>
    /// Assigns a consistent MudBlazor Color to an avatar based on the initials string.
    /// Uses a deterministic hash (sum of char codes × prime) so the same initials
    /// always produce the same color, even across process restarts (.NET 6+
    /// randomizes <see cref="string.GetHashCode"/> per process).
    /// </summary>
    private static Color GetAvatarColor(string initials)
    {
        // Deterministic hash — sum of character codes multiplied by prime
        var hash = initials.Aggregate(0, (h, c) => h * 31 + c);
        var colors = new[] { Color.Primary, Color.Secondary, Color.Tertiary, Color.Info, Color.Success, Color.Warning, Color.Error };
        return colors[Math.Abs(hash) % colors.Length];
    }

    /// <summary>
    /// Formats large numbers into compact human-readable strings.
    /// Examples: 987 → "987", 21800 → "21.8K", 108000 → "108K"
    /// </summary>
    private static string FormatCount(int count) => count switch
    {
        >= 1_000_000 => $"{count / 1_000_000.0:0.#}M",
        >= 1_000     => $"{count / 1_000.0:0.#}K",
        _            => count.ToString()
    };
}
