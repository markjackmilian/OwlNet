@page "/"

@* ═══════════════════════════════════════════════════════════════════════════════
   OwlNet Kanban Dashboard — Home Page
   ═══════════════════════════════════════════════════════════════════════════════
   A showcase Kanban board with three status columns (In Progress, Reviewed,
   Completed), drag-and-drop task cards, priority badges, avatar groups, and
   engagement stats. All data is hardcoded — no backend calls.

   Layout structure:
   ┌─────────────────────────────────────────────────────────────────┐
   │ Kanban Dashboard 🤖              [🔍] [Share ↗] [📤] [+]       │
   ├─────────────────────────────────────────────────────────────────┤
   │ By Status | By Total Tasks (12) | Tasks Due | ... | Sort By ▼  │
   ├─────────────────────────────────────────────────────────────────┤
   │ ┌──────────────┐ ┌──────────────┐ ┌──────────────┐             │
   │ │ 25 In Progr +│ │ 8 Reviewed  +│ │ 2 Completed +│             │
   │ ├──────────────┤ ├──────────────┤ ├──────────────┤             │
   │ │ [Card 1]     │ │ [Card 1]     │ │ [Card 1]     │             │
   │ │ [Card 2]     │ │ [Card 2]     │ │ [Card 2]     │             │
   │ │ ...          │ │ ...          │ │ ...          │             │
   │ └──────────────┘ └──────────────┘ └──────────────┘             │
   └─────────────────────────────────────────────────────────────────┘

   Drag & drop: Uses MudBlazor's MudDropContainer<T> / MudDropZone<T> for
   functional card reordering between columns. Dropping a card into a new
   column updates its KanbanStatus.

   Render mode: InteractiveServer (inherited from App.razor routing).
   ═══════════════════════════════════════════════════════════════════════════════ *@

<PageTitle>Kanban Dashboard — OwlNet</PageTitle>

@* ── Section 1: Page Header ──────────────────────────────────────────────────
   Title with emoji on the left, action buttons on the right.
   Matches the reference: search, share, upload, and add buttons. *@
<MudStack Row="true"
           Justify="Justify.SpaceBetween"
           AlignItems="AlignItems.Center"
           Class="mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">
        Kanban Dashboard 🤖
    </MudText>
    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
        @* Search icon button *@
        <MudIconButton Icon="@Icons.Material.Filled.Search"
                       Size="Size.Medium"
                       aria-label="Search tasks" />
        @* Share button — filled primary with icon *@
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Share"
                   Size="Size.Small"
                   Class="kanban-share-btn">
            Share
        </MudButton>
        @* Upload icon button *@
        <MudIconButton Icon="@Icons.Material.Filled.FileUpload"
                       Size="Size.Medium"
                       aria-label="Upload file" />
        @* Add new task button *@
        <MudIconButton Icon="@Icons.Material.Filled.Add"
                       Size="Size.Medium"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       aria-label="Add new task" />
    </MudStack>
</MudStack>

@* ── Section 2: Tab Bar + Sort Dropdown ──────────────────────────────────────
   Horizontal tabs for different views, with a "Sort By" dropdown on the right.
   The tab bar uses MudTabs with Elevation=0 for a flat, inline look. *@
<MudStack Row="true"
           Justify="Justify.SpaceBetween"
           AlignItems="AlignItems.Center"
           Class="mb-5">
    <MudTabs Elevation="0"
             Rounded="true"
             ApplyEffectsToContainer="true"
             Class="kanban-tabs"
             Color="Color.Primary">
        <MudTabPanel Text="By Status" />
        <MudTabPanel>
            @* Custom tab header with a count badge *@
            <TabContent>
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.body2">By Total Tasks</MudText>
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="Color.Primary"
                             Variant="Variant.Filled"
                             Class="kanban-tab-badge">
                        @_tasks.Count
                    </MudChip>
                </MudStack>
            </TabContent>
        </MudTabPanel>
        <MudTabPanel Text="Tasks Due" />
        <MudTabPanel Text="Extra Tasks" />
        <MudTabPanel Text="Tasks Completed" />
    </MudTabs>

    @* Sort dropdown — positioned to the right of the tabs *@
    <MudSelect T="string"
               Value="@_sortBy"
               ValueChanged="@(v => _sortBy = v)"
               Label="Sort By"
               Variant="Variant.Outlined"
               Dense="true"
               Margin="Margin.Dense"
               Class="kanban-sort-select">
        <MudSelectItem Value="@("Newest")">Newest</MudSelectItem>
        <MudSelectItem Value="@("Oldest")">Oldest</MudSelectItem>
        <MudSelectItem Value="@("Priority")">Priority</MudSelectItem>
    </MudSelect>
</MudStack>

@* ── Section 3: Kanban Board (Drag & Drop) ───────────────────────────────────
   MudDropContainer wraps the entire board. Each column is a MudDropZone
   identified by the KanbanStatus enum name. Cards can be dragged between
   columns, and the ItemDropped handler updates the task's status.

   MudBlazor 9.1.0 API:
   - Items: the full list of draggable items
   - ItemsSelector: Func<T, string, bool> — returns true if item belongs to zone
   - ItemDropped: EventCallback<MudItemDropInfo<T>> — fires on drop
   - ItemRenderer: RenderFragment<T> — renders each card
   - ChildContent: the zone layout (columns) *@
<MudDropContainer T="KanbanTask"
                  Items="_tasks"
                  ItemsSelector="@((item, zone) => item.Status.ToString() == zone)"
                  ItemDropped="OnItemDropped"
                  Class="kanban-drop-container">
    <ChildContent>
        <div class="kanban-board">
            @* ── Column: In Progress ─────────────────────────────────────── *@
            <div class="kanban-column">
                <div class="kanban-column-header kanban-column-header--indigo">
                    <div class="kanban-column-count">@GetColumnCount(KanbanStatus.InProgress)</div>
                    <span class="kanban-column-title">In Progress</span>
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   Class="kanban-column-add"
                                   aria-label="Add task to In Progress" />
                </div>
                <MudDropZone T="KanbanTask"
                             Identifier="InProgress"
                             AllowReorder="true"
                             Class="kanban-dropzone" />
            </div>

            @* ── Column: Reviewed ────────────────────────────────────────── *@
            <div class="kanban-column">
                <div class="kanban-column-header kanban-column-header--orange">
                    <div class="kanban-column-count">@GetColumnCount(KanbanStatus.Reviewed)</div>
                    <span class="kanban-column-title">Reviewed</span>
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   Class="kanban-column-add"
                                   aria-label="Add task to Reviewed" />
                </div>
                <MudDropZone T="KanbanTask"
                             Identifier="Reviewed"
                             AllowReorder="true"
                             Class="kanban-dropzone" />
            </div>

            @* ── Column: Completed ───────────────────────────────────────── *@
            <div class="kanban-column">
                <div class="kanban-column-header kanban-column-header--green">
                    <div class="kanban-column-count">@GetColumnCount(KanbanStatus.Completed)</div>
                    <span class="kanban-column-title">Completed</span>
                    <MudIconButton Icon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   Class="kanban-column-add"
                                   aria-label="Add task to Completed" />
                </div>
                <MudDropZone T="KanbanTask"
                             Identifier="Completed"
                             AllowReorder="true"
                             Class="kanban-dropzone" />
            </div>
        </div>
    </ChildContent>

    @* ── Item Renderer: Task Card ────────────────────────────────────────────
       Each card displays:
       1. Priority badge (colored pill)
       2. Title (bold)
       3. Description (gray, clamped to 3 lines)
       4. Footer: avatar group (left) + comment/view counts (right) *@
    <ItemRenderer>
        <div class="kanban-card">
            @* Priority badge — colored pill indicating task urgency *@
            <span class="kanban-card-priority @GetPriorityClass(context.Priority)">
                @GetPriorityLabel(context.Priority)
            </span>

            @* Task title *@
            <MudText Typo="Typo.subtitle1" Class="kanban-card-title">
                @context.Title
            </MudText>

            @* Task description — clamped to 3 lines via CSS *@
            <MudText Typo="Typo.body2" Class="kanban-card-description">
                @context.Description
            </MudText>

            @* Footer row: avatars on left, stats on right *@
            <div class="kanban-card-footer">
                @* Avatar group — shows team member initials with overflow count *@
                <MudAvatarGroup Max="3"
                                Spacing="2"
                                MaxSize="Size.Small"
                                MaxColor="Color.Primary"
                                Class="kanban-avatar-group">
                    @foreach (var initials in context.Avatars)
                    {
                        <MudAvatar Size="Size.Small"
                                   Variant="Variant.Filled"
                                   Color="@GetAvatarColor(initials)"
                                   Class="kanban-avatar">
                            @initials
                        </MudAvatar>
                    }
                </MudAvatarGroup>

                @* Engagement stats: comments and views *@
                <div class="kanban-card-stats">
                    @* Comment count *@
                    <span class="kanban-card-stat">
                        <MudIcon Icon="@Icons.Material.Outlined.ChatBubbleOutline"
                                 Size="Size.Small" />
                        @FormatCount(context.Comments)
                    </span>
                    @* View count *@
                    <span class="kanban-card-stat">
                        <MudIcon Icon="@Icons.Material.Outlined.Visibility"
                                 Size="Size.Small" />
                        @FormatCount(context.Views)
                    </span>
                </div>
            </div>
        </div>
    </ItemRenderer>
</MudDropContainer>

@code {
    // ═══════════════════════════════════════════════════════════════════════════
    //  Enums — define the task priority levels and Kanban column statuses.
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>Task priority levels with distinct visual colors.</summary>
    private enum TaskPriority
    {
        Important,
        HighPriority,
        Meh,
        OK,
        LowPriority,
