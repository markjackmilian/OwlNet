    // ═══════════════════════════════════════════════════════════════════════════
    //  Data Model — KanbanTask holds all info needed to render a card.
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>
    /// Represents a single task card on the Kanban board.
    /// Mutable Status property allows drag-and-drop to update the column.
    /// </summary>
    private class KanbanTask
    {
        /// <summary>Unique task identifier.</summary>
        public int Id { get; set; }

        /// <summary>Task title displayed prominently on the card.</summary>
        public string Title { get; set; } = "";

        /// <summary>Brief description shown below the title (clamped to 3 lines).</summary>
        public string Description { get; set; } = "";

        /// <summary>Priority level — determines the badge color and label.</summary>
        public TaskPriority Priority { get; set; }

        /// <summary>Current column — updated when the card is dropped in a new zone.</summary>
        public KanbanStatus Status { get; set; }

        /// <summary>Team member initials for the avatar group (e.g., "AW", "JD").</summary>
        public List<string> Avatars { get; set; } = [];

        /// <summary>Number of comments on this task.</summary>
        public int Comments { get; set; }

        /// <summary>Number of views/impressions on this task.</summary>
        public int Views { get; set; }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  State — sort selection and task list
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>Currently selected sort option for the dropdown.</summary>
    private string _sortBy = "Newest";

    /// <summary>
    /// All Kanban tasks — distributed across the three columns.
    /// This is the single source of truth; MudDropContainer reads from this list
    /// and the ItemsSelector filters by Status matching the zone Identifier.
    /// </summary>
