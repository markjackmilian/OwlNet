@page "/not-found"
@layout MainLayout

@* 404 page — uses MudBlazor components for visual consistency *@
<PageTitle>Not Found</PageTitle>

<MudCard Style="max-width: 600px; margin: 2rem auto; text-align: center;">
    <MudCardContent>
        <MudStack Spacing="4" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Large" />
            <MudText Typo="Typo.h4">
                Not Found
            </MudText>
            <MudText>
                Sorry, the content you are looking for does not exist.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">
                Go to Home
            </MudButton>
        </MudStack>
    </MudCardContent>
</MudCard>
