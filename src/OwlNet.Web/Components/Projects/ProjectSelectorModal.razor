@* ═══════════════════════════════════════════════════════════════════════════════
   Project Selector Modal — Smart Component
   ═══════════════════════════════════════════════════════════════════════════════
   Full-featured modal for browsing, searching, creating, editing, and archiving
   projects. Opened from the topbar project indicator in MainLayout.

   UI states (driven by _viewMode):
   ┌──────────┐  ┌──────────────────────────────────────────────────────────────┐
   │ List     │  │ Searchable list of non-archived projects                     │
   │          │  │  ┌─ Search field (client-side filter)                        │
   │          │  │  ├─ Project items with actions menu (Edit, Archive)          │
   │          │  │  ├─ Empty state when no projects / no search results         │
   │          │  │  └─ "New Project" button                                     │
   ├──────────┤  ├──────────────────────────────────────────────────────────────┤
   │ Create   │  │ Form with Name + Description fields + Save/Cancel           │
   ├──────────┤  ├──────────────────────────────────────────────────────────────┤
   │ Edit     │  │ Pre-filled form with Name + Description + Save/Cancel       │
   └──────────┘  └──────────────────────────────────────────────────────────────┘

   Services injected:
   - IRequestHandler (DispatchR) — for all CQRS commands/queries
   - ISnackbar — toast notifications
   - ActiveProjectService — manages the active project context
   - IDialogService — archive confirmation dialog

   Spec reference: SPEC-001-project-crud (FR-16 through FR-27)
   ═══════════════════════════════════════════════════════════════════════════════ *@

@using DispatchR.Abstractions.Send
@using OwlNet.Application.Common.Models
@using OwlNet.Application.Projects.Commands.ArchiveProject
@using OwlNet.Application.Projects.Commands.CreateProject
@using OwlNet.Application.Projects.Commands.UpdateProject
@using OwlNet.Application.Projects.Queries.GetAllProjects
@using OwlNet.Application.Projects.Queries.GetProjectById
@using OwlNet.Web.Services

@inject IRequestHandler<GetAllProjectsQuery, ValueTask<Result<List<ProjectDto>>>> GetAllProjectsHandler
@inject IRequestHandler<CreateProjectCommand, ValueTask<Result<Guid>>> CreateProjectHandler
@inject IRequestHandler<UpdateProjectCommand, ValueTask<Result>> UpdateProjectHandler
@inject IRequestHandler<ArchiveProjectCommand, ValueTask<Result>> ArchiveProjectHandler
@inject IRequestHandler<GetProjectByIdQuery, ValueTask<Result<ProjectDto>>> GetProjectByIdHandler
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ActiveProjectService ActiveProjectService

@implements IDisposable

<MudDialog>
    <TitleContent>
        @switch (_viewMode)
        {
            case ViewMode.List:
                <MudText Typo="Typo.h6">Select a Project</MudText>
                break;
            case ViewMode.Create:
                <MudText Typo="Typo.h6">New Project</MudText>
                break;
            case ViewMode.Edit:
                <MudText Typo="Typo.h6">Edit Project</MudText>
                break;
        }
    </TitleContent>

    <DialogContent>
        @if (_viewMode == ViewMode.List)
        {
            @* ── List View ──────────────────────────────────────────────────── *@
            <MudStack Spacing="3">
                @if (_isLoading)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        <MudText Typo="Typo.body2">Loading projects...</MudText>
                    </MudStack>
                }
                else
                {
                    @* Search field — filters projects client-side *@
                    <MudTextField T="string"
                                  Value="@_searchText"
                                  ValueChanged="@OnSearchTextChanged"
                                  Placeholder="Search projects..."
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true"
                                  Clearable="true"
                                  Class="mb-2" />

                    @if (_filteredProjects.Count == 0)
                    {
                        @if (_projects.Count == 0)
                        {
                            @* Empty state — no projects exist *@
                            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="py-6">
                                <MudIcon Icon="@Icons.Material.Filled.FolderOpen"
                                         Size="Size.Large"
                                         Color="Color.Default" />
                                <MudText Typo="Typo.body1" Align="Align.Center">
                                    No projects yet. Create your first project!
                                </MudText>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="@SwitchToCreateView">
                                    New Project
                                </MudButton>
                            </MudStack>
                        }
                        else
                        {
                            @* No search results *@
                            <MudText Typo="Typo.body2" Align="Align.Center" Class="py-4">
                                No projects match your search.
                            </MudText>
                        }
                    }
                    else
                    {
                        @* Project list *@
                        <MudList T="ProjectDto" Dense="true" Class="project-list">
                            @foreach (var project in _filteredProjects)
                            {
                                <MudListItem T="ProjectDto"
                                             OnClick="@(() => SelectProjectAsync(project))"
                                             Class="project-list-item">
                                    <ChildContent>
                                        <MudStack Row="true"
                                                   AlignItems="AlignItems.Center"
                                                   Justify="Justify.SpaceBetween"
                                                   Style="width: 100%;">
                                            <MudStack Spacing="0" Style="flex: 1; min-width: 0;">
                                                <MudText Typo="Typo.body1"
                                                         Style="font-weight: 500;">
                                                    @project.Name
                                                </MudText>
                                                @if (!string.IsNullOrWhiteSpace(project.Description))
                                                {
                                                    <MudText Typo="Typo.body2"
                                                             Color="Color.Secondary"
                                                             Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                                        @project.Description
                                                    </MudText>
                                                }
                                            </MudStack>

                                            @* Actions menu — Edit and Archive *@
                                            <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                                                     Size="Size.Small"
                                                     Dense="true"
                                                     AnchorOrigin="Origin.BottomRight"
                                                     TransformOrigin="Origin.TopRight"
                                                     aria-label="@($"Actions for {project.Name}")">
                                                <MudMenuItem OnClick="@(() => SwitchToEditView(project))"
                                                             Icon="@Icons.Material.Filled.Edit">
                                                    Edit
                                                </MudMenuItem>
                                                <MudMenuItem OnClick="@(() => ArchiveProjectAsync(project))"
                                                             Icon="@Icons.Material.Filled.Archive"
                                                             IconColor="Color.Warning">
                                                    Archive
                                                </MudMenuItem>
                                            </MudMenu>
                                        </MudStack>
                                    </ChildContent>
                                </MudListItem>
                            }
                        </MudList>
                    }
                }
            </MudStack>
        }
        else
        {
            @* ── Create / Edit Form ─────────────────────────────────────────── *@
            <MudStack Spacing="3">
                <MudTextField T="string"
                              @bind-Value="_formName"
                              Label="Name"
                              Required="true"
                              RequiredError="Project name is required"
                              Variant="Variant.Outlined"
                              Counter="100"
                              MaxLength="100"
                              Immediate="true"
                              Error="@(!string.IsNullOrEmpty(_formNameError))"
                              ErrorText="@_formNameError"
                              Disabled="@_isSaving" />

                <MudTextField T="string"
                              @bind-Value="_formPath"
                              Label="Path"
                              Required="true"
                              RequiredError="Project path is required"
                              Variant="Variant.Outlined"
                              Counter="500"
                              MaxLength="500"
                              Immediate="true"
                              Error="@(!string.IsNullOrEmpty(_formPathError))"
                              ErrorText="@_formPathError"
                              Disabled="@(_isSaving || _viewMode == ViewMode.Edit)"
                              HelperText="@(_viewMode == ViewMode.Edit ? "Path cannot be changed after creation" : "Absolute path to the project folder")" />

                <MudTextField T="string"
                              @bind-Value="_formDescription"
                              Label="Description (optional)"
                              Variant="Variant.Outlined"
                              Lines="3"
                              Counter="500"
                              MaxLength="500"
                              Disabled="@_isSaving" />

                @if (!string.IsNullOrEmpty(_formError))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                        @_formError
                    </MudAlert>
                }
            </MudStack>
        }
    </DialogContent>

    <DialogActions>
        @if (_viewMode == ViewMode.List)
        {
            @if (_projects.Count > 0)
            {
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="@SwitchToCreateView">
                    New Project
                </MudButton>
            }
            <MudSpacer />
            <MudButton Variant="Variant.Text"
                       OnClick="@Cancel">
                Close
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Text"
                       OnClick="@BackToList"
                       Disabled="@_isSaving">
                Cancel
            </MudButton>
            <MudSpacer />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@IsSaveDisabled"
                       OnClick="@SaveAsync">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small"
                                         Indeterminate="true"
                                         Class="mr-2" />
                    @:Saving...
                }
                else
                {
                    @:Save
                }
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    // ═══════════════════════════════════════════════════════════════════════════
    //  Parameters
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>The MudDialog instance reference, used to close the dialog.</summary>
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    // ═══════════════════════════════════════════════════════════════════════════
    //  State — view mode, projects, form fields
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>Controls which view is displayed in the modal.</summary>
    private ViewMode _viewMode = ViewMode.List;

    /// <summary>True while the project list is being loaded.</summary>
    private bool _isLoading = true;

    /// <summary>True while a save operation (create/update) is in progress.</summary>
    private bool _isSaving;

    /// <summary>All non-archived projects loaded from the server.</summary>
    private List<ProjectDto> _projects = [];

    /// <summary>Projects filtered by the search text.</summary>
    private List<ProjectDto> _filteredProjects = [];

    /// <summary>The current search text for filtering projects.</summary>
    private string _searchText = string.Empty;

    /// <summary>The project being edited (null when creating).</summary>
    private ProjectDto? _editingProject;

    // ── Form fields ────────────────────────────────────────────────────────

    /// <summary>The project name in the create/edit form.</summary>
    private string _formName = string.Empty;

    /// <summary>The absolute filesystem path in the create form. Read-only in edit mode.</summary>
    private string _formPath = string.Empty;

    /// <summary>The project description in the create/edit form.</summary>
    private string _formDescription = string.Empty;

    /// <summary>Inline error for the name field (e.g., duplicate name).</summary>
    private string _formNameError = string.Empty;

    /// <summary>Inline error for the path field (e.g., duplicate path, directory not found).</summary>
    private string _formPathError = string.Empty;

    /// <summary>General form error message.</summary>
    private string _formError = string.Empty;

    /// <summary>Cancellation token source for in-flight operations.</summary>
    private readonly CancellationTokenSource _cts = new();

    // ═══════════════════════════════════════════════════════════════════════════
    //  Computed Properties
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>
    /// Save button is disabled when the name is too short or a save is in progress.
    /// </summary>
    private bool IsSaveDisabled =>
        string.IsNullOrWhiteSpace(_formName) || _formName.Trim().Length < 3 || _isSaving
        || (_viewMode == ViewMode.Create && string.IsNullOrWhiteSpace(_formPath));

    // ═══════════════════════════════════════════════════════════════════════════
    //  Lifecycle
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>Loads the project list when the modal opens.</summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadProjectsAsync();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  Data Loading
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>Loads all non-archived projects from the server.</summary>
    private async Task LoadProjectsAsync()
    {
        _isLoading = true;
        StateHasChanged();

        var query = new GetAllProjectsQuery();
        var result = await GetAllProjectsHandler.Handle(query, _cts.Token);

        if (result.IsSuccess)
        {
            _projects = result.Value;
            ApplySearchFilter();
        }

        _isLoading = false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  Search / Filter
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>Handles search text changes and applies client-side filtering.</summary>
    private void OnSearchTextChanged(string value)
    {
        _searchText = value ?? string.Empty;
        ApplySearchFilter();
    }

    /// <summary>Filters the project list by name using case-insensitive contains match.</summary>
    private void ApplySearchFilter()
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            _filteredProjects = [.. _projects];
        }
        else
        {
            _filteredProjects = _projects
                .Where(p => p.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  Project Selection
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>Selects a project as active and closes the modal.</summary>
    private async Task SelectProjectAsync(ProjectDto project)
    {
        await ActiveProjectService.SetActiveProjectAsync(project);
        MudDialog.Close(DialogResult.Ok(project));
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  View Mode Switching
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>Switches to the create form view with empty fields.</summary>
    private void SwitchToCreateView()
    {
        _viewMode = ViewMode.Create;
        _editingProject = null;
        _formName = string.Empty;
        _formPath = string.Empty;
        _formDescription = string.Empty;
        ClearFormErrors();
    }

    /// <summary>Switches to the edit form view pre-filled with the project's data.</summary>
    private void SwitchToEditView(ProjectDto project)
    {
        _viewMode = ViewMode.Edit;
        _editingProject = project;
        _formName = project.Name;
        _formPath = project.Path;
        _formDescription = project.Description;
        ClearFormErrors();
    }

    /// <summary>Returns to the list view, reloading projects to reflect any changes.</summary>
    private async Task BackToList()
    {
        _viewMode = ViewMode.List;
        _editingProject = null;
        ClearFormErrors();
        await LoadProjectsAsync();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  Save — Create or Update
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>Saves the form — creates a new project or updates an existing one.</summary>
    private async Task SaveAsync()
    {
        ClearFormErrors();
        _isSaving = true;
        StateHasChanged();

        try
        {
            if (_viewMode == ViewMode.Create)
            {
                await CreateProjectAsync();
            }
            else if (_viewMode == ViewMode.Edit && _editingProject is not null)
            {
                await UpdateProjectAsync();
            }
        }
        catch (Exception)
        {
            _formError = "An error occurred. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    /// <summary>Creates a new project via the CreateProjectCommand.</summary>
    private async Task CreateProjectAsync()
    {
        var command = new CreateProjectCommand
        {
            Name = _formName.Trim(),
            Path = _formPath.Trim(),
            Description = string.IsNullOrWhiteSpace(_formDescription) ? null : _formDescription.Trim()
        };

        var result = await CreateProjectHandler.Handle(command, _cts.Token);

        if (result.IsSuccess)
        {
            Snackbar.Add("Project created successfully.", Severity.Success);
            await BackToList();
        }
        else
        {
            HandleSaveError(result.Error);
        }
    }

    /// <summary>Updates an existing project via the UpdateProjectCommand.</summary>
    private async Task UpdateProjectAsync()
    {
        var command = new UpdateProjectCommand
        {
            Id = _editingProject!.Id,
            Name = _formName.Trim(),
            Description = string.IsNullOrWhiteSpace(_formDescription) ? null : _formDescription.Trim()
        };

        var result = await UpdateProjectHandler.Handle(command, _cts.Token);

        if (result.IsSuccess)
        {
            Snackbar.Add("Project updated successfully.", Severity.Success);

            // If the updated project is the active project, refresh its data
            if (ActiveProjectService.ActiveProject?.Id == _editingProject!.Id)
            {
                var refreshQuery = new GetProjectByIdQuery { Id = _editingProject.Id };
                var refreshResult = await GetProjectByIdHandler.Handle(refreshQuery, _cts.Token);
                if (refreshResult.IsSuccess)
                {
                    ActiveProjectService.UpdateActiveProjectData(refreshResult.Value);
                }
            }

            await BackToList();
        }
        else
        {
            HandleSaveError(result.Error);
        }
    }

    /// <summary>Routes save errors to the appropriate form field or general error area.</summary>
    private void HandleSaveError(string error)
    {
        if (error.Contains("name already exists", StringComparison.OrdinalIgnoreCase))
        {
            _formNameError = error;
        }
        else if (error.Contains("path already exists", StringComparison.OrdinalIgnoreCase)
                 || error.Contains("directory does not exist", StringComparison.OrdinalIgnoreCase))
        {
            _formPathError = error;
        }
        else
        {
            _formError = error;
        }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  Archive
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>Archives a project after user confirmation.</summary>
    private async Task ArchiveProjectAsync(ProjectDto project)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Archive Project",
            $"Are you sure you want to archive '{project.Name}'? You can restore it later.",
            yesText: "Archive",
            cancelText: "Cancel");

        if (confirmed != true)
        {
            return;
        }

        var command = new ArchiveProjectCommand { Id = project.Id };
        var result = await ArchiveProjectHandler.Handle(command, _cts.Token);

        if (result.IsSuccess)
        {
            Snackbar.Add("Project archived.", Severity.Success);

            // If the archived project was the active project, clear the context
            if (ActiveProjectService.ActiveProject?.Id == project.Id)
            {
                await ActiveProjectService.ClearActiveProjectAsync();
            }

            await LoadProjectsAsync();
        }
        else
        {
            Snackbar.Add(result.Error, Severity.Error);
        }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  Helpers
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>Clears all form error messages.</summary>
    private void ClearFormErrors()
    {
        _formNameError = string.Empty;
        _formPathError = string.Empty;
        _formError = string.Empty;
    }

    /// <summary>Closes the modal without selecting a project.</summary>
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    /// <inheritdoc />
    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  View Mode Enum
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>Controls which view is displayed in the modal.</summary>
    private enum ViewMode
    {
        /// <summary>Searchable list of projects.</summary>
        List,

        /// <summary>Form for creating a new project.</summary>
        Create,

        /// <summary>Form for editing an existing project.</summary>
        Edit
    }
}
