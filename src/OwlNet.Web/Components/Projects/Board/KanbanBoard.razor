@* ═══════════════════════════════════════════════════════════════════════════════
   KanbanBoard — Presentational (Dumb) Component
   ═══════════════════════════════════════════════════════════════════════════════
   Renders the full project Kanban board with dynamic columns driven by the
   project's BoardStatusDto list. Columns are ordered by SortOrder and colored
   deterministically from a fixed palette based on their index position.

   Uses MudBlazor's MudDropContainer<T> / MudDropZone<T> for drag-and-drop
   card movement between columns. Each drop zone is identified by the status
   Guid string. Dropping a card into a different column raises the
   OnCardStatusChanged callback so the parent can persist the change.

   This is a pure presentational component: it receives data via parameters
   and communicates user interactions via EventCallback. No data fetching or
   business logic — only rendering and event forwarding.

   Spec reference: SPEC-C4-board-wiring
   ═══════════════════════════════════════════════════════════════════════════════ *@

@using OwlNet.Application.Common.Models

@inject IDialogService DialogService

@* ═══════════════════════════════════════════════════════════════════════════════
   MudDropContainer — wraps the entire board.
   - Items: the full list of draggable cards (CardDto)
   - ItemsSelector: maps each card to its column by matching StatusId to zone ID
   - ItemDropped: fires synchronously when a card is dropped; delegates to async
   - ItemRenderer: renders each card using the KanbanCard component
   - ChildContent: the dynamic column layout (one drop zone per status)
   ═══════════════════════════════════════════════════════════════════════════════ *@
<MudDropContainer T="CardDto"
                  @ref="_dropContainer"
                  Items="Cards"
                  ItemsSelector="@((item, zone) => item.StatusId.ToString() == zone)"
                  ItemDropped="OnItemDropped"
                  Class="board-drop-container">
    <ChildContent>
        <div class="board-layout">
            @{
                // Sort statuses by SortOrder to ensure consistent column ordering
                var orderedStatuses = Statuses.OrderBy(s => s.SortOrder).ToList();
            }
            @for (var i = 0; i < orderedStatuses.Count; i++)
            {
                var status = orderedStatuses[i];

                @* Capture loop variable for use in lambda — avoids closure capture bug *@
                var columnIndex = i;

                @* Deterministic color from the fixed palette based on column position *@
                var headerColor = _colorPalette[columnIndex % _colorPalette.Length];

                <div class="board-column">

                    @* ── Column Header ────────────────────────────────────────
                       Colored bar with card count badge, status name, and an
                       "Add card" button (SPEC-C5 placeholder).
                       Color is applied as an inline style since statuses are
                       dynamic — CSS modifier classes are no longer used. *@
                    <div class="board-column-header" style="background-color: @headerColor">
                        <div class="board-column-count">@GetColumnCount(status.Id)</div>
                        <span class="board-column-title">@status.Name</span>
                        @* Opens CreateCardDialog with this column's status pre-filled (SPEC-C5 FR #1) *@
                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                       Size="Size.Small"
                                       Class="board-column-add"
                                       OnClick="@(() => _ = InvokeAsync(() => OpenCreateCardDialogAsync(status)))"
                                       aria-label="@($"Add card to {status.Name}")" />
                    </div>

                    @* ── Drop Zone ────────────────────────────────────────────
                       Each zone is identified by the status Guid string.
                       AllowReorder enables card reordering within the same column. *@
                    <MudDropZone T="CardDto"
                                 Identifier="@status.Id.ToString()"
                                 AllowReorder="true"
                                 Class="board-dropzone" />
                </div>
            }
        </div>
    </ChildContent>

    @* ── Item Renderer ────────────────────────────────────────────────────────
       Delegates card rendering to the KanbanCard component, which handles
       priority badge, card number, title, Markdown description, and tags. *@
    <ItemRenderer>
        <KanbanCard Card="@context" OnCardClicked="OnCardClicked" />
    </ItemRenderer>
</MudDropContainer>

@code {
    // ═══════════════════════════════════════════════════════════════════════════
    //  Parameters
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>
    /// The board statuses that define the columns, ordered by SortOrder.
    /// Each status becomes one drop zone on the board.
    /// </summary>
    [Parameter, EditorRequired]
    public List<BoardStatusDto> Statuses { get; set; } = [];

    /// <summary>
    /// The list of cards to display across the columns.
    /// Each card's <see cref="CardDto.StatusId"/> determines which column it appears in.
    /// Cards whose StatusId does not match any loaded status are silently excluded.
    /// </summary>
    [Parameter, EditorRequired]
    public List<CardDto> Cards { get; set; } = [];

    /// <summary>
    /// The owning project ID. Passed to child components for context
    /// (e.g., the "Add card" dialog in SPEC-C5).
    /// </summary>
    [Parameter, EditorRequired]
    public Guid ProjectId { get; set; }

    /// <summary>
    /// Callback raised when a card is dropped into a different column.
    /// The parent (Board.razor) handles persistence via ChangeCardStatusCommand.
    /// The tuple carries the original CardDto and the target status Guid.
    /// </summary>
    [Parameter]
    public EventCallback<(CardDto Card, Guid NewStatusId)> OnCardStatusChanged { get; set; }

    /// <summary>
    /// Callback raised when a card was modified inside the detail dialog.
    /// The parent (Board.razor) handles this to refresh the board data.
    /// </summary>
    [Parameter]
    public EventCallback OnCardChanged { get; set; }

    // ═══════════════════════════════════════════════════════════════════════════
    //  Color Palette
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>
    /// Fixed color palette for column headers. Colors are assigned deterministically
    /// by index (position in the SortOrder-sorted status list) so the same status
    /// always gets the same color within a session. The palette cycles if there
    /// are more than 10 statuses.
    /// </summary>
    private static readonly string[] _colorPalette =
    [
        "#6B7280", // 0 — slate gray
        "#8B5CF6", // 1 — violet
        "#3B82F6", // 2 — blue
        "#F59E0B", // 3 — amber
        "#10B981", // 4 — emerald
        "#EF4444", // 5 — red
        "#F97316", // 6 — orange
        "#06B6D4", // 7 — cyan
        "#84CC16", // 8 — lime
        "#EC4899"  // 9 — pink
    ];

    // ═══════════════════════════════════════════════════════════════════════════
    //  Drop Container Reference
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>
    /// Reference to the MudDropContainer. Used by the parent (Board.razor) to
    /// call <see cref="RefreshItems"/> after the card list is updated, so the
    /// container re-distributes cards into their correct drop zones.
    /// </summary>
    private MudDropContainer<CardDto>? _dropContainer;

    // ═══════════════════════════════════════════════════════════════════════════
    //  Public API
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>
    /// Instructs the <see cref="MudDropContainer{T}"/> to re-evaluate its
    /// <c>ItemsSelector</c> and redistribute all items into their correct drop zones.
    /// Must be called by the parent after the <see cref="Cards"/> list is replaced
    /// (e.g., after a card is created or the board is refreshed).
    /// </summary>
    public void RefreshItems()
    {
        _dropContainer?.Refresh();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  Event Handlers
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>
    /// Synchronous MudDropContainer callback — bridges to the async handler.
    /// MudDropContainer's ItemDropped is synchronous (Action&lt;T&gt;), but we need
    /// to call async operations. We use InvokeAsync to marshal back onto the
    /// Blazor synchronization context and fire the async handler.
    /// </summary>
    /// <param name="info">Drop event info containing the dragged item and target zone.</param>
    private void OnItemDropped(MudItemDropInfo<CardDto> info)
    {
        _ = InvokeAsync(() => HandleDropAsync(info));
    }

    /// <summary>
    /// Async drop handler. Parses the drop zone identifier as a Guid and raises
    /// <see cref="OnCardStatusChanged"/> if the card moved to a different column.
    /// Same-column drops are silently ignored.
    /// </summary>
    /// <param name="info">Drop event info containing the dragged item and target zone.</param>
    private async Task HandleDropAsync(MudItemDropInfo<CardDto> info)
    {
        if (info.Item is null)
        {
            return;
        }

        if (!Guid.TryParse(info.DropzoneIdentifier, out var newStatusId))
        {
            return;
        }

        // Same-column drop — no-op, nothing to persist
        if (info.Item.StatusId == newStatusId)
        {
            return;
        }

        await OnCardStatusChanged.InvokeAsync((info.Item, newStatusId));
    }

    /// <summary>
    /// Handles a card click by opening the <see cref="CardDetailDialog"/> modal.
    /// Passes both the card and the project ID so the dialog can load
    /// project-scoped statuses and tags (SPEC-C6).
    /// </summary>
    /// <param name="card">The card that was clicked.</param>
    private async Task OnCardClicked(CardDto card)
    {
        var parameters = new DialogParameters<CardDetailDialog>
        {
            { x => x.Card, card },
            { x => x.ProjectId, ProjectId }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseOnEscapeKey = true,
            CloseButton = true
        };

        var dialogRef = await DialogService.ShowAsync<CardDetailDialog>(
            string.Empty, // Title is rendered inside TitleContent — no outer title needed
            parameters,
            options);

        var result = await dialogRef.Result;

        // If the card was modified, notify the parent board to refresh its data
        if (result is { Canceled: false, Data: true })
        {
            await OnCardChanged.InvokeAsync();
        }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  Card Creation
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>
    /// Opens <see cref="CreateCardDialog"/> with the given column's status pre-filled.
    /// Called from the "Add card" icon button in each column header (SPEC-C5 FR #1).
    /// After a successful creation the parent board is notified via
    /// <see cref="OnCardChanged"/> so it can refresh its card list.
    /// </summary>
    /// <param name="status">The board status whose ID is pre-filled in the dialog.</param>
    private async Task OpenCreateCardDialogAsync(BoardStatusDto status)
    {
        var parameters = new DialogParameters<CreateCardDialog>
        {
            { x => x.ProjectId, ProjectId },
            { x => x.PrefilledStatusId, status.Id }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true,
            CloseButton = true
        };

        var dialogRef = await DialogService.ShowAsync<CreateCardDialog>(
            string.Empty, // Title is rendered inside TitleContent — no outer title needed
            parameters,
            options);

        var result = await dialogRef.Result;

        // If the card was created, notify the parent board to refresh its data
        if (result is { Canceled: false, Data: true })
        {
            await OnCardChanged.InvokeAsync();
        }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    //  Helpers
    // ═══════════════════════════════════════════════════════════════════════════

    /// <summary>
    /// Returns the number of cards currently in the specified column.
    /// Used by the column header to display a live count badge.
    /// </summary>
    /// <param name="statusId">The board status ID (column) to count cards for.</param>
    /// <returns>The number of cards with the given status ID.</returns>
    private int GetColumnCount(Guid statusId) =>
        Cards.Count(c => c.StatusId == statusId);
}
